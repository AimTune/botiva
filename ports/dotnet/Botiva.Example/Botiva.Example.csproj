<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Botiva.Example</RootNamespace>
    <Description>botiva — ASP.NET Core demo server: ChatClientRuntime + MapBotiva + MCP tools (ModelContextProtocol) + Claude (Anthropic SDK); deterministic by default (no API key), with --selftest.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Botiva\Botiva.csproj" />
    <ProjectReference Include="..\Botiva.AspNetCore\Botiva.AspNetCore.csproj" />
    <ProjectReference Include="..\Botiva.Agents\Botiva.Agents.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- MCP server (Streamable HTTP) + client — official C# MCP SDK -->
    <PackageReference Include="ModelContextProtocol.AspNetCore" Version="2.0.0-preview.3" />
    <!-- Claude Messages API — official Anthropic C# SDK -->
    <PackageReference Include="Anthropic" Version="12.35.1" />
  </ItemGroup>

</Project>
