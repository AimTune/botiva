<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Botiva.Agents</RootNamespace>
    <Description>botiva — Microsoft.Extensions.AI runtime adapter: plug any IChatClient (OpenAI, Azure, Ollama, Semantic Kernel via AsChatClient) into the botiva Runtime port, with tool tracing and LangGraph-style interrupt() HITL.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI" Version="10.8.0" />
    <ProjectReference Include="..\Botiva\Botiva.csproj" />
  </ItemGroup>

</Project>
