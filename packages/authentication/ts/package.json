{
    "name": "@botiva/authentication",
    "version": "0.1.0",
    "description": "botiva authentication adapters — static-token, HMAC-JWT and cookie Authenticator implementations for the @botiva/core auth port.",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@botiva/core": "workspace:^"
    },
    "engines": {
        "node": ">=18.17"
    }
}
