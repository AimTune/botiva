{
    "name": "@botiva/socket.io",
    "version": "0.1.0",
    "description": "botiva Socket.IO transport connector — speaks Botiva Wire Protocol v1 over a single event channel.",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "sideEffects": false,
    "publishConfig": { "access": "public" },
    "dependencies": {
        "@botiva/core": "workspace:^"
    },
    "peerDependencies": {
        "socket.io": ">=4"
    },
    "devDependencies": {
        "socket.io": "^4.8.1"
    },
    "engines": { "node": ">=18.17" }
}
